# Telegram Bot Token (Get it from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# MongoDB Connection URI
MONGO_URI=mongodb://localhost:27017/ielts_bot

# Claude API Key (Enter 'mock' to run in test/offline mode)
CLAUDE_API_KEY=mock

# Optional: Claude Custom Base/API URL (e.g. if using a custom proxy/endpoint)
CLAUDE_API_URL=

# Optional: Claude model selection (defaults to claude-3-5-sonnet-latest)
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Optional: Admin Chat ID for manual payment approvals (e.g. 12345678)
# If left empty, the bot will search for a user with the username 'identitynull' in the DB
ADMIN_CHAT_ID=

# Admin API Configuration
JWT_SECRET=change_me_in_production_with_a_strong_secret
ADMIN_API_PORT=3001
